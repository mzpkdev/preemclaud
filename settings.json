{
  "model": "opusplan",
  "effortLevel": "high",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Agent",
      "Skill",
      "NotebookEdit",
      "mcp__*"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf .)",
      "Bash(rm -rf ./*)",
      "Bash(sudo rm -rf*)",
      "Bash(git push --force*)",
      "Bash(git push * --force*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(git checkout -- .)",
      "Bash(git branch -D *)",
      "Bash(chmod -R 777*)",
      "Bash(mkfs.*)",
      "Bash(dd if=*of=/dev/*)",
      "Bash(> /dev/sda*)",
      "Bash(curl * | bash*)",
      "Bash(wget * | bash*)",
      "Bash(curl * | sh*)",
      "Bash(wget * | sh*)",
      "Bash(shutdown*)",
      "Bash(reboot*)",
      "Bash(halt*)",
      "Bash(kill -9 -1*)",
      "Bash(launchctl unload*)",
      "Bash(Remove-Item * -Recurse -Force*)",
      "Bash(Remove-Item -Recurse -Force*)",
      "Bash(ri * -Recurse -Force*)",
      "Bash(rd /s /q*)",
      "Bash(rmdir /s /q*)",
      "Bash(del /f /s /q*)",
      "Bash(Format-Volume*)",
      "Bash(format *:*)",
      "Bash(Stop-Computer*)",
      "Bash(Restart-Computer*)",
      "Bash(shutdown /s*)",
      "Bash(shutdown /r*)",
      "Bash(Stop-Process -Force*)",
      "Bash(taskkill /f /im *)",
      "Bash(sc delete *)",
      "Bash(Stop-Service *)",
      "Bash(Invoke-Expression*)",
      "Bash(iex *)",
      "Bash(irm * | iex*)",
      "Bash(icacls * /grant Everyone:F*)",
      "Bash(net stop *)",
      "Bash(reg delete *)"
    ],
    "defaultMode": "dontAsk"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/update.py\""
          }
        ]
      }
    ]
  },
  "voiceEnabled": true,
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "skipDangerousModePermissionPrompt": true
}
