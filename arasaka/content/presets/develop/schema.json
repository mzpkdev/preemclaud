          "items": { "type": "string" }
        },
        "verification": {
          "type": "array",
          "items": { "type": "string" }
        },
        "assumptions": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["title", "summary", "changes", "verification", "assumptions"],
      "additionalProperties": false
    },
    "issue_comment": {
