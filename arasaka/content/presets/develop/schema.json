{
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "status": { "const": "implemented" },
        "pull_request": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "summary": { "type": "string" },
            "changes": {
              "type": "array",
              "items": { "type": "string" }
            },
            "verification": {
              "type": "array",
              "items": { "type": "string" }
            },
            "assumptions": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "required": ["title", "summary", "changes", "verification", "assumptions"],
          "additionalProperties": false
        },
        "issue_comment": {
          "type": "object",
          "properties": {
            "summary": { "type": "string" },
            "verification": {
              "type": "array",
              "items": { "type": "string" }
            },
            "follow_ups": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "required": ["summary", "verification", "follow_ups"],
          "additionalProperties": false
        }
      },
      "required": ["status", "pull_request", "issue_comment"],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "status": { "const": "needs_decomposition" },
        "summary": { "type": "string" },
        "reason": { "type": "string" },
        "child_issues": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "summary": { "type": "string" },
              "problem": { "type": "string" },
              "acceptance_criteria": {
                "type": "array",
                "items": { "type": "string" }
              },
              "evidence": {
                "type": "array",
                "items": { "type": "string" }
              },
              "labels": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "required": ["title", "summary", "problem", "acceptance_criteria", "evidence", "labels"],
            "additionalProperties": false
          }
        }
      },
      "required": ["status", "summary", "reason", "child_issues"],
      "additionalProperties": false
    }
  ]
}
