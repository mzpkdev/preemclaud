{
  "type": "object",
  "properties": {
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "action": { "type": "string", "enum": ["create", "update"] },
          "existing_issue_number": { "type": "integer" },
          "title": { "type": "string" },
          "summary": { "type": "string" },
          "problem": { "type": "string" },
          "acceptance_criteria": {
            "type": "array",
            "items": { "type": "string" }
          },
          "evidence": {
            "type": "array",
            "items": { "type": "string" }
          },
          "labels": {
            "type": "array",
            "items": { "type": "string" }
          },
          "priority": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          }
        },
        "required": [
          "action",
          "title",
          "summary",
          "problem",
          "acceptance_criteria",
          "evidence",
          "labels",
          "priority"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": ["issues"],
  "additionalProperties": false
}
